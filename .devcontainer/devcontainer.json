{
  "name": "RoyalTest",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // Expose Flask port to the LAN (appPort uses Docker -p, accessible from other devices)
  //"appPort": [5000],

  // Bind-mount Claude Code binary and config from the host
  "mounts": [
    "source=${localEnv:HOME}/.local/share/claude,target=/home/vscode/.local/share/claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached"
  ],

  // Symlink the claude binary into PATH and pass the API key through from the host
  "containerEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },

  "postCreateCommand": "sudo ln -sf /home/vscode/.local/share/claude/versions/$(ls /home/vscode/.local/share/claude/versions | sort -V | tail -1) /usr/local/bin/claude && pip install -r requirements.txt",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylint",
        "ms-python.black-formatter",
        "ritwickdey.LiveServer"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-python.black-formatter",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        }
      }
    }
  },

  "remoteUser": "vscode",
  "runArgs": ["-p", "5000:5000"]
}
